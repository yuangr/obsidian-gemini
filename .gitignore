# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Coverage reports
coverage/


# Agent tool configs (keep skills symlinks + maintainerd config, ignore everything else)
.gemini/*
!.gemini/skills/
.claude/*
!.claude/skills/
# Maintainerd repo config — must be tracked so cloud sessions (fresh clone) and the
# plugin marketplace declaration reach the toolkit. See .claude/maintainerd.json.
!.claude/maintainerd.json
!.claude/settings.json
!.claude/guidelines/

# Obsidian debug logs
obsidian.md-*.log

# Development test scripts
test-scripts/

# TypeScript incremental compilation info
*.tsbuildinfo

# Eval results (regenerated per run)
evals/results/

# VitePress
docs/.vitepress/dist/
docs/.vitepress/cache/

# Claude Design sync — local pin to a personal claude.ai/design project.
# Not a secret (just a project UUID, no token), but it's personal account state,
# not shared config — keep it out of this public repo. Auth lives in the local
# Claude config from /design-login, never here.
.design-sync/